{
  "name": "chess-academy-pro",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "stockfish:check": "node validate-stockfish.cjs",
    "stockfish:copy": "mkdir -p public/stockfish && cp node_modules/stockfish/bin/stockfish-18-lite-single.js public/stockfish/ && cp node_modules/stockfish/bin/stockfish-18-lite-single.wasm public/stockfish/",
    "prebuild": "node validate-stockfish.cjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "postinstall": "npm run stockfish:copy",
    "setup:ios": "npx cap add ios; npx cap sync ios; cp ios-patches/App/AppDelegate.swift ios/App/App/AppDelegate.swift",
    "audit:voice": "node scripts/audit-voice-coverage.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@capacitor/core": "8.1.0",
    "chess.js": "1.4.0",
    "dexie": "4.3.0",
    "framer-motion": "12.34.4",
    "lucide-react": "0.576.0",
    "openai": "^6.27.0",
    "react": "19.2.4",
    "react-chessboard": "5.10.0",
    "react-dom": "19.2.4",
    "react-router-dom": "7.13.1",
    "recharts": "3.7.0",
    "stockfish": "^18.0.5",
    "zustand": "5.0.11"
  },
  "devDependencies": {
    "@capacitor/cli": "8.1.0",
    "@capacitor/ios": "8.1.0",
    "@playwright/test": "1.58.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "fake-indexeddb": "6.2.5",
    "fzstd": "^0.1.1",
    "jsdom": "^28.1.0",
    "msw": "2.12.10",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.19",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "4.0.18",
    "vitest-axe": "^0.1.0"
  }
}
