{
  "rewrites": [
    {
      "source": "/voice-packs/:file",
      "destination": "https://github.com/dyahnke-pro/chess-academy-pro/releases/download/voice-packs-v1/:file"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/stockfish/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" }
      ]
    }
  ]
}
