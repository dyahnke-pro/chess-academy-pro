# Chess Academy Pro — environment variables
#
# Copy this file to `.env.local` (gitignored) to run the app locally.
# In production (Vercel), set the same keys under:
#   Project Settings → Environment Variables
#
# Surfaces:
#   [build]     — read by Vite at build time, baked into the bundle
#                 (via `define` in vite.config.ts).
#   [vercel-fn] — read at runtime by serverless functions in `api/*`.
#   [local]     — used only by scripts in `scripts/` or by Playwright.
#
# Client-side runtime keys live in IndexedDB (encrypted via
# cryptoService) — NOT in env vars. See Settings → Coach.

# ─── LLM providers ──────────────────────────────────────────────────────────
# Optional. When set at build time, they pre-seed the coach so the
# user doesn't have to paste a key before trying the app. Users can
# still override via Settings.
# [build]
ANTHROPIC_KEY=
DEEPSEEK_KEY=

# ─── Amazon Polly TTS (server-side voice) ──────────────────────────────────
# Required for /api/tts to work. Without these, the app falls back to
# Web Speech API in-browser.
# [vercel-fn]
AWS_ACCESS_KEY_ID_POLLY=
AWS_SECRET_ACCESS_KEY_POLLY=
AWS_REGION_POLLY=us-east-1

# ─── Audit stream (Upstash Redis, optional) ─────────────────────────────────
# If set, /api/audit-stream persists client error reports into a
# short-TTL Redis list. If unset, audits stay in-memory and evaporate
# between cold starts — fine for local dev.
# [vercel-fn]
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Aliases Vercel sets automatically when using the Upstash
# integration — the handler reads either pair.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Shared secret required to POST to /api/audit-stream. Set to a long
# random string. Must match what the client sends in x-audit-secret.
# [vercel-fn]
AUDIT_STREAM_SECRET=

# ─── Observability ─────────────────────────────────────────────────────────
# Sentry + PostHog are no-ops when these are unset, so leaving them
# blank is fine for local dev. In Vercel, set them only on Production
# (and optionally Preview) scope. See docs/ENV-VARS.md.
# [build]
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
# Opt in to PostHog tracking from a dev build (useful for debugging the
# reverse-proxy wiring). Leave blank in CI and production.
# [build]
VITE_POSTHOG_ALLOW_DEV=

# Sentry source-map upload (build-time only; never a runtime concern).
# Setting all three enables the sentryVitePlugin to upload maps on
# `npm run build`. Otherwise the plugin is a no-op.
# [build-scope-on-vercel]
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Playwright E2E ─────────────────────────────────────────────────────────
# Gates the /auth/test-login route so production bundles never expose
# it. Only set to 'true' on the Preview scope used by CI.
# [build]
VITE_ALLOW_TEST_LOGIN=

# ─── Scripts (local only) ──────────────────────────────────────────────────
# Used by `npm run data:audit`, grade-narrations.ts, etc. Never
# shipped to Vercel.
# [local]
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# ─── Supabase test user seeding (local/CI only) ────────────────────────────
# Used by scripts/seed-test-user.ts. The script refuses to run unless
# the URL looks like a test/staging project, so these are never used
# against production by accident.
# [local]
SUPABASE_TEST_PROJECT_URL=
SUPABASE_TEST_SERVICE_ROLE=
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# ─── Supabase CLI ──────────────────────────────────────────────────────────
# Not needed in .env — `supabase login` + `supabase link` write a
# per-machine token under .supabase/ (gitignored). See
# supabase/README.md for the full workflow.
